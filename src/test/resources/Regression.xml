<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >

<suite name="Regression">
    <parameter name="BaseURL" value="https://qa.koel.app/"/>
    <test name="Regression Test" preserve-order="false">
        <classes>
            <class name="LoginTests">
                <methods>
                    <include name="loginWithIncorrectEmail"/>
                    <include name="loginWithIncorrectPassword"/>
                </methods>
            </class>
            <class name="PlayerTests">
                <methods>
                    <include name="hoverCheck"/>
                </methods>
            </class>
            <class name="PlayListTests">
                <methods>
                    <exclude name="renamePlaylist"/>
                </methods>
            </class>
            <class name="ProfilePageTest">
                <methods>
                    <include name="changeCurrentTheme"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>